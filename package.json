{
  "name": "@rippling/pebble-playground",
  "version": "1.0.0",
  "description": "AI-friendly prototyping environment for Rippling's Pebble Design System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 4201",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "new:demo": "node scripts/create-demo.mjs",
    "catalog": "node scripts/generate-catalog.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\""
  },
  "dependencies": {
    "@rippling/pebble": "latest",
    "@rippling/lib-i18n": "latest",
    "@rippling/ui-utils": "latest",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-json-view": "^1.21.3",
    "react-shadow": "^20.3.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

